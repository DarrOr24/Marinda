{
  "cli": {
    "version": ">= 16.19.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "review": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_REVIEWER_LOGIN_ENABLED": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_REVIEWER_LOGIN_ENABLED": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
