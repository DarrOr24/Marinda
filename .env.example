# Supabase (required for the app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Reviewer login – When set, shows "Reviewer: log in" on login.
EXPO_PUBLIC_REVIEWER_LOGIN_ENABLED=false

# Dev login – Dev only. When set, shows "Dev: log in without OTP" on login.
EXPO_PUBLIC_DEV_LOGIN_SECRET=

# RevenueCat – one key for both platforms, or use _IOS / _ANDROID for platform-specific
EXPO_PUBLIC_REVENUECAT_API_KEY=
# EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
# EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
